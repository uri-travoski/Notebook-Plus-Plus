# ─────────────────────────────────────────────────────────────────────────────
# App runtime (Nuxt). Used in dev (`npm run dev`) and read inside the container.
# ─────────────────────────────────────────────────────────────────────────────

# Postgres connection string.
# Dev: points at the local Docker container published on 127.0.0.1:5438.
# Docker: the compose file builds this from DB_PASSWORD (see below).
NUXT_DATABASE_URL=postgres://notebookpp:devpassword@127.0.0.1:5438/notebookpp

# Sealed-cookie session secret (nuxt-auth-utils). MUST be >= 32 characters.
NUXT_SESSION_PASSWORD=replace_with_a_long_random_string_at_least_32_chars

# Secret used to derive the AES-256-GCM key that encrypts AI provider keys at
# rest. Any length (it is hashed to 32 bytes). Keep it stable and secret.
ENCRYPTION_KEY=replace_with_a_random_secret

# Public base URL — used to build password-reset links.
NUXT_PUBLIC_APP_URL=http://localhost:3000

# Allow self-registration. Set to "false" after the single account exists.
ALLOW_REGISTRATION=true

# Mark the session cookie Secure. Leave unset/false for plain-HTTP LAN access
# (a Secure cookie is rejected by browsers over http on a non-localhost IP).
# Set to "true" when serving over HTTPS (e.g. behind Nginx Proxy Manager).
NUXT_SESSION_COOKIE_SECURE=false

# SMTP URL for password-reset email (nodemailer, e.g. smtp://user:pass@host:587).
# Leave empty in dev to log the reset link to the server console instead.
SMTP_URL=

# ─────────────────────────────────────────────────────────────────────────────
# Docker compose only (see docker-compose.yml). Not needed for `npm run dev`.
# ─────────────────────────────────────────────────────────────────────────────

# Postgres password for the bundled db service.
DB_PASSWORD=replace_with_a_strong_password

# Same as NUXT_SESSION_PASSWORD; the compose file maps it through. >= 32 chars.
SESSION_PASSWORD=replace_with_a_long_random_string_at_least_32_chars
