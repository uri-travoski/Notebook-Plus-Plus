{
  "name": "notebookpp",
  "version": "0.23.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "preview": "nuxt preview",
    "start": "node .output/server/index.mjs",
    "postinstall": "node scripts/copy-excalidraw-assets.mjs && nuxt prepare",
    "typecheck": "nuxt typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node --env-file=.env server/db/migrate.mjs",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx server/db/seed.ts",
    "db:reset": "tsx server/db/reset.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test --grep-invert @sim",
    "test:sim": "playwright test e2e/simulation.spec.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.4",
    "@ai-sdk/google": "^4.0.3",
    "@ai-sdk/groq": "^4.0.2",
    "@ai-sdk/openai": "^4.0.4",
    "@blocknote/code-block": "^0.51.4",
    "@blocknote/core": "^0.51.4",
    "@blocknote/mantine": "^0.51.4",
    "@blocknote/react": "^0.51.4",
    "@blocknote/server-util": "^0.51.4",
    "@excalidraw/excalidraw": "^0.18.1",
    "@fontsource-variable/fira-code": "^5.2.7",
    "@fontsource-variable/google-sans-code": "^5.2.4",
    "@fontsource-variable/inter": "5.2.8",
    "@fontsource-variable/jetbrains-mono": "5.2.8",
    "@fontsource-variable/lora": "^5.2.8",
    "@fontsource-variable/merriweather": "^5.2.6",
    "@fontsource-variable/noto-sans": "^5.2.10",
    "@fontsource/google-sans": "^5.2.1",
    "@fontsource/ibm-plex-serif": "^5.2.7",
    "@fontsource/libre-baskerville": "^5.2.10",
    "ai": "^7.0.9",
    "drizzle-orm": "0.45.2",
    "fractional-indexing": "^4.0.0",
    "h3": "1.15.11",
    "jszip": "^3.10.1",
    "katex": "^0.17.0",
    "lucide-vue-next": "^1.0.0",
    "nodemailer": "^9.0.3",
    "nuxt": "3.21.8",
    "nuxt-auth-utils": "^0.5.29",
    "pg": "8.22.0",
    "pg-boss": "^12.24.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "shiki": "^4.3.0",
    "veaury": "^2.6.3",
    "vue": "^3.5.39",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@nuxt/eslint": "1.16.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "4.3.2",
    "@types/katex": "^0.16.8",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vite-pwa/nuxt": "^1.1.1",
    "@vitejs/plugin-react": "^5.2.0",
    "dotenv": "17.4.2",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "happy-dom": "20.10.6",
    "prettier": "3.9.4",
    "tailwindcss": "4.3.2",
    "tsx": "4.22.4",
    "typescript": "5.9.3",
    "vitest": "4.1.9",
    "vue-tsc": "3.3.5"
  }
}
