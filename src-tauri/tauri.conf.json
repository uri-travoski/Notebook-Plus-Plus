{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Notebook++ Portable",
  "version": "0.62.17",
  "identifier": "com.notebookpp.desktop",
  "build": {
    "frontendDist": "frontend",
    "devUrl": "http://localhost:3940",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build && node scripts/prepare-tauri-resources.mjs"
  },
  "app": {
    "windows": [
      {
        "title": "Notebook++ Portable",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/pg0"],
    "resources": [
      "resources/server/**/*",
      "resources/public/**/*"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
